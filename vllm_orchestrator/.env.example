# vLLM Orchestrator — environment variables template
# Copy to .env and customize. Env vars override config.yaml

# === Runtime ===
APP_ENV=gpu                           # gpu | cpu | dev
APP_DEBUG=false
CONFIG_PATH=configs/app_config.yaml

# === LLM backend ===
LLM_BASE_URL=http://localhost:8000
LLM_API_KEY=internal-token
LLM_API_KEY_ENV_NAME=LLM_API_KEY       # Orchestrator에서 실제 API key를 담은 env var 이름
LLM_MODEL=/mnt/d/LLM/models/Qwen2.5-14B-Instruct-AWQ
LLM_TEXT_MODEL_ID=core_text_14b
LLM_CODE_MODEL_ID=core_text_14b
LLM_RUNTIME_MODE=local_quantized
LLM_QUANTIZATION=awq_marlin
LLM_ENABLE_ADAPTERS=false
LLM_ENABLE_GUIDED_JSON=true
LLM_MAX_CONTEXT=2048
LLM_MAX_OUTPUT_TOKENS=800

# === Queue ===
QUEUE_CONCURRENCY=4

# === Cache ===
REQUEST_CACHE_DISABLED=0
REQUEST_CACHE_BACKEND=auto            # auto | memory | redis
REQUEST_CACHE_TTL_S=3600
REQUEST_CACHE_MAX=1000
REDIS_URL=redis://localhost:6379/0

# === Semantic cache ===
SEMANTIC_CACHE_DISABLED=0
SEMANTIC_CACHE_MAX=500
SEMANTIC_CACHE_TTL_S=3600
SEMANTIC_CACHE_THRESHOLD=0.55

# === Creative layer ===
LLM_CRITIC_MODE=inline                # inline | async | off
VARIANT_SAMPLING_DISABLED=0

# === Auth & rate limit ===
API_KEY_REQUIRED=0
API_KEYS=                              # comma-separated
RATE_LIMIT_RPS=2.0
RATE_LIMIT_BURST=20
RATE_LIMIT_BACKEND=auto                # auto | memory | redis

# === Storage paths (relative to STORAGE_DIR or absolute) ===
STORAGE_DIR=./storage
LOGS_DIR=./logs
FEEDBACK_LOG_PATH=                     # 비워두면 STORAGE_DIR/feedback.jsonl
TRAINING_DATA_DIR=                     # 비워두면 STORAGE_DIR/training_data
ADAPTERS_DIR=                          # 비워두면 STORAGE_DIR/adapters
BENCHMARK_DIR=                         # 비워두면 STORAGE_DIR/benchmark_scores

# === Observability ===
METRICS_ENABLED=1
LOG_LEVEL=INFO

# === CORS / security ===
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3457,http://127.0.0.1:5173

# === HuggingFace cache (downstream) ===
HF_HOME=/data/hf_cache
HF_HUB_CACHE=/data/hf_cache
TRANSFORMERS_CACHE=/data/hf_cache
