# Local Quantized Mode — RTX 5070 12GB VRAM / 64GB RAM
# Canonical model: Qwen2.5-14B-Instruct-AWQ (unified text + code)
#
# Constraints respected:
#  - 12GB VRAM: model weights ~9.5GB (AWQ 4bit) + KV cache ~1GB
#  - gpu-memory-utilization=0.88 (10.5GB target, leaves headroom for other GPU users)
#  - max-model-len=6144 (balances KV cache availability with useful context)

APP_ENV=gpu
LLM_TEXT_MODEL_ID=core_text_14b
LLM_CODE_MODEL_ID=core_text_14b
LLM_RUNTIME_MODE=local_quantized
LLM_QUANTIZATION=awq_marlin
LLM_ENDPOINT=http://localhost:8000
LLM_BASE_URL=http://localhost:8000
LLM_API_KEY=internal-token
LLM_MODEL=/mnt/d/LLM/models/Qwen2.5-14B-Instruct-AWQ
LLM_MAX_CONTEXT=2048
LLM_MAX_OUTPUT_TOKENS=768
LLM_ENABLE_ADAPTERS=false
LLM_ENABLE_GUIDED_JSON=true
QUEUE_CONCURRENCY=2

# HuggingFace cache (D drive to preserve C:)
HF_HOME=D:/hf_cache
HF_HUB_CACHE=D:/hf_cache
TRANSFORMERS_CACHE=D:/hf_cache
