# Remote Production Mode — vLLM cluster with full-precision 32B
# Multi-GPU deployment with LoRA adapters enabled

APP_ENV=gpu
LLM_TEXT_MODEL_ID=core_text_32b
LLM_CODE_MODEL_ID=core_code_32b
LLM_RUNTIME_MODE=remote_full
LLM_QUANTIZATION=none
LLM_ENDPOINT=http://llm-cluster:8000
LLM_API_KEY_ENV_NAME=LLM_PRODUCTION_API_KEY
LLM_MAX_CONTEXT=32768
LLM_MAX_OUTPUT_TOKENS=512
LLM_ENABLE_ADAPTERS=true
QUEUE_CONCURRENCY=8
