{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resource Pack Style",
  "type": "object",
  "required": ["name", "palette", "textures"],
  "properties": {
    "name": {"type": "string"},
    "era": {"type": "string"},
    "palette": {"type": "array", "items": {"type": "string"}, "minItems": 3, "maxItems": 8},
    "mood": {"type": "string"},
    "textures": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["block_id", "name", "base_color", "pattern"],
        "properties": {
          "block_id": {"type": "string"},
          "name": {"type": "string"},
          "base_color": {"type": "string"},
          "accent_color": {"type": "string"},
          "pattern": {"type": "string", "enum": ["solid","brick","wood","cobble","ore","leaf","glass","log","plank","mossy","cracked","carved","smooth"]},
          "noise_level": {"type": "number", "minimum": 0, "maximum": 1},
          "wear_level": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
